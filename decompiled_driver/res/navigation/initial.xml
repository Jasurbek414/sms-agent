<?xml version="1.0" encoding="utf-8"?>
<navigation android:id="@id/initial" app:startDestination="@id/loaderFragment"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <fragment android:label="LoaderFragment" android:name="su.skat.client.foreground.LoaderFragment" android:id="@id/loaderFragment">
        <action android:id="@id/action_loaderFragment_to_privacyFragment" app:destination="@id/privacyFragment" app:popUpTo="@id/loaderFragment" />
        <action android:id="@id/action_loaderFragment_to_welcomeFragment" app:destination="@id/welcomeFragment" />
        <action android:id="@id/action_loaderFragment_to_permissionsFragment" app:destination="@id/permissionsFragment" app:popUpTo="@id/loaderFragment" />
        <action android:id="@id/action_loaderFragment_to_overlayPermissionFragment" app:destination="@id/overlayPermissionFragment" app:popUpTo="@id/loaderFragment" />
        <action android:id="@id/action_loaderFragment_to_statusPanelFragment" app:destination="@id/statusPanelFragment" />
    </fragment>
    <fragment android:label="fragment_privacy" android:name="su.skat.client.foreground.not_authorized.PrivacyFragment" android:id="@id/privacyFragment" />
    <fragment android:label="WelcomeFragment" android:name="su.skat.client.foreground.not_authorized.welcome.WelcomeFragment" android:id="@id/welcomeFragment">
        <action android:id="@id/action_welcomeFragment_to_loginFragment" app:destination="@id/loginFragment" app:popUpTo="@id/welcomeFragment" />
        <action android:id="@id/action_welcomeFragment_to_registerFragment" app:destination="@id/registerFragment" app:popUpTo="@id/welcomeFragment" />
    </fragment>
    <fragment android:label="LoginFragment" android:name="su.skat.client.foreground.not_authorized.welcome.LoginFragment" android:id="@id/loginFragment">
        <action android:id="@id/action_loginFragment_to_preferencesFragment" app:destination="@id/preferencesFragment" app:popUpTo="@id/loaderFragment" />
    </fragment>
    <fragment android:label="RegisterFragment" android:name="su.skat.client.foreground.not_authorized.welcome.RegisterFragment" android:id="@id/registerFragment">
        <action android:id="@id/action_registerFragment_to_loginFragment" app:destination="@id/loginFragment" app:popUpTo="@id/registerFragment" />
        <action android:id="@id/action_registerFragment_to_driverFormFragment" app:destination="@id/driverFormFragment" app:popUpTo="@id/loaderFragment" />
    </fragment>
    <fragment android:label="PermissionsFragment" android:name="su.skat.client.foreground.not_authorized.PermissionsFragment" android:id="@id/permissionsFragment" />
    <fragment android:label="OverlayPermissionFragment" android:name="su.skat.client.foreground.not_authorized.OverlayPermissionFragment" android:id="@id/overlayPermissionFragment" />
    <fragment android:label="StatusPanelFragment" android:name="su.skat.client.foreground.authorized.StatusPanelFragment" android:id="@id/statusPanelFragment">
        <action android:id="@id/action_statusPanelFragment_to_main" app:destination="@id/main" />
    </fragment>
    <fragment android:label="PreferencesFragment" android:name="su.skat.client.foreground.authorized.mainMenu.preferences.PreferencesFragment" android:id="@id/preferencesFragment" />
    <fragment android:label="DriverFormFragment" android:name="su.skat.client.foreground.not_authorized.welcome.DriverFormFragment" android:id="@id/driverFormFragment">
        <argument android:name="registrationId" app:argType="string" />
        <action android:id="@id/action_driverFormFragment_to_preferencesFragment" app:destination="@id/preferencesFragment" app:popUpTo="@id/loaderFragment" app:popUpToInclusive="true" />
    </fragment>
    <include app:graph="@navigation/main" />
</navigation>