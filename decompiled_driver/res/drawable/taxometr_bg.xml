<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="?warnBackground" />
            <stroke android:width="2.0dip" android:color="?warnBackground" />
            <corners android:radius="2.0dip" />
            <padding android:left="10.0dip" android:top="10.0dip" android:right="10.0dip" android:bottom="10.0dip" />
        </shape>
    </item>
    <item android:state_hovered="true">
        <shape>
            <solid android:color="?accentedButtonBackground" />
            <stroke android:width="2.0dip" android:color="?accentedButtonBackground" />
            <corners android:radius="2.0dip" />
            <padding android:left="10.0dip" android:top="10.0dip" android:right="10.0dip" android:bottom="10.0dip" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="?backColor" />
            <stroke android:width="1.0dip" android:color="?backColor" />
            <corners android:radius="2.0dip" />
            <padding android:left="10.0dip" android:top="10.0dip" android:right="10.0dip" android:bottom="10.0dip" />
        </shape>
    </item>
</selector>